{
  "name": "logseq-plugin-daily-todo",
  "version": "0.0.10",
  "license": "MIT",
  "main": "index.html",
  "logseq": {
    "id": "logseq-plugin-daily-todo",
    "title": "Daily TODO",
    "icon": "./icon.png"
  },
  "packageManager": "pnpm@9.15.0",
  "engines": {
    "node": ">=20.19"
  },
  "scripts": {
    "build": "vite build && cp README.md LICENSE icon.png package.json dist/",
    "check": "tsc --noEmit",
    "lint": "eslint .",
    "test": "vitest run",
    "test:watch": "vitest",
    "perf": "node scripts/perf.mjs",
    "verify": "pnpm check && pnpm lint && pnpm test && pnpm build && pnpm perf",
    "test:e2e": "bash e2e/run.sh",
    "test:e2e:quick": "bash e2e/run.sh --quick",
    "test:e2e:shortcuts": "bash e2e/run.sh --shortcuts"
  },
  "devDependencies": {
    "@eslint/js": "^9.0.0",
    "@types/node": "^22.10.0",
    "eslint": "^9.0.0",
    "globals": "^17.0.0",
    "playwright": "^1.59.1",
    "typescript": "^5.9.0",
    "typescript-eslint": "^8.0.0",
    "vite": "^7.1.0",
    "vitest": "^3.0.0"
  },
  "dependencies": {
    "@logseq/libs": "0.0.17"
  }
}
